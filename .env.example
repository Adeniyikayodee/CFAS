# Copy to .env and fill in. The pipeline reads these on start.

# Earth Engine project. Run `earthengine authenticate` once on this machine.
EE_PROJECT=your-earth-engine-project-id

# Google Maps Platform Weather API. This makes the rainfall term predictive,
# reading up to 10 days of forward forecast. Enable the Weather API in your
# Google Cloud project, then paste the key here. Without it, P reads GFS.
GOOGLE_WEATHER_KEY=your-google-maps-platform-key

# Gemma 3 drafting. Point CACTUS_URL at a local Cactus server for the edge path.
# A llama.cpp GGUF at GEMMA_MODEL serves as the laptop / Raspberry Pi fallback.
CACTUS_URL=http://127.0.0.1:8080
GEMMA_MODEL=gemma-3-it.gguf

# NLLB-200 translation
NLLB_MODEL=facebook/nllb-200-distilled-600M

# Speech-to-text for the listener call-in loop (Cactus on device; faster-whisper fallback)
STT_MODEL=base

# Optional: ping a radio partner by SMS through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
